{
  "name": "identity-backend-monorepo",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "build": "turbo --concurrency=${TURBO_CONCURRENCY:-50%} build",
    "typecheck": "turbo --concurrency=${TURBO_CONCURRENCY:-50%} --continue typecheck",
    "test": "turbo --concurrency=${TURBO_CONCURRENCY:-50%} test --filter=!./apps/*-e2e --filter=!@identity-backend/vitest-config",
    "test:e2e:identity": "pnpm --filter identity-backend-e2e test:e2e",
    "test:e2e:ci:identity": "CI=true pnpm --filter identity-backend-e2e test:e2e",
    "test:e2e:local": "./scripts/e2e-local.sh",
    "test:e2e:dotns-chopsticks": "./scripts/e2e-local.sh tests/v1/dotns-sanity.test.ts",
    "test:e2e:parallel": "CI=true pnpm -r --parallel test:e2e",
    "test:staging": "pnpm --filter identity-backend-e2e exec tsx scripts/stress-staging.ts",
    "db:generate": "pnpm -r db:generate",
    "effect:layer": "bun scripts/effect-ls.ts layer",
    "effect:diagnose": "bun scripts/effect-ls.ts diagnose",
    "effect:overview": "bun scripts/effect-ls.ts overview",
    "lint": "pnpm format:check && turbo --concurrency=${TURBO_CONCURRENCY:-50%} lint ${AGENT:+-- --format=unix}",
    "lint:ci": "pnpm format:check && turbo --concurrency=${TURBO_CONCURRENCY:-50%} lint -- --format=github",
    "lint:force": "turbo --concurrency=${TURBO_CONCURRENCY:-50%} lint --force && pnpm format:check",
    "api:check": "turbo --concurrency=${TURBO_CONCURRENCY:-50%} api:check",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "prepare": "husky",
    "postinstall": "turbo build --filter='./packages/**'",
    "precommit": "pnpm lint-staged --no-revert",
    "pre-push": "concurrently --group \"pnpm lint\" \"pnpm typecheck\" \"pnpm api:check\" \"CI=true pnpm test\"",
    "check:ci": "concurrently --group --no-bail \"pnpm lint:ci\" \"pnpm typecheck\" \"pnpm api:check\" \"pnpm --filter identity-backend-container run check:env-sync\" \"pnpm run check:migrations\"",
    "check:migrations": "./scripts/check-migrations.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@effect/language-service": "^0.85.1",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/oxlint-plugin": "workspace:^",
    "@identity-backend/backend-cli": "workspace:^",
    "@semantic-release/commit-analyzer": "catalog:",
    "@semantic-release/git": "catalog:",
    "@semantic-release/github": "catalog:",
    "@semantic-release/release-notes-generator": "catalog:",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "concurrently": "^9.2.1",
    "dprint": "^0.54.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "latest",
    "rimraf": "^6.1.3",
    "semantic-release": "catalog:",
    "ts-morph": "^28.0.0",
    "tshy": "^3.1.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.x.x"
  },
  "packageManager": "pnpm@10.28.2"
}
