# ===============================================
# Network Configuration
# ===============================================

# Options: westend2, polkadot, paseo
PEOPLE_NETWORK=paseo
# Comma-separated WSS endpoints for the People chain. Replace with a public RPC or your own node.
PEOPLE_RPC_ENDPOINTS=wss://people-paseo.dotters.network
# Options: previewnet_people, paseo_people, paseo_people_next
PEOPLE_CHAIN_DESCRIPTOR=previewnet_people

# WebSocket heartbeat timeout in milliseconds (increase for dev environments like chopsticks)
WEBSOCKET_HEARTBEAT_TIMEOUT=60000

# ===============================================
# Account Configuration
# ===============================================

# sr25519 64-byte expanded private key (can be generated using scripts/private-key.ts)
PROXY_PRIVATE_KEY=
# Whether to use proxy delegation for attestation submissions
PROXY_DELEGATION_ENABLED=false
# sr25519 64-byte expanded private key for the attester proxy account (required when PROXY_DELEGATION_ENABLED=true)
ATTESTER_PROXY_PRIVATE_KEY=
# Attester public key as a hex string
ATTESTER_PUBLIC_KEY=0xd43593c715fdd31c61141abd04a99fd6822c8558854ccde39a5684e7a56da27d

# ===============================================
# Username Configuration
# ===============================================

# Maximum time to wait for the first transaction event when registering a username on-chain
SET_USERNAME_FOR_TIMEOUT=12000

# ===============================================
# Username Indexer Configuration
# ===============================================

# Enable/disable the username indexer background service
USERNAME_INDEXER_ENABLED=false
# Interval in milliseconds between username indexer sync runs
USERNAME_INDEXER_SYNC_INTERVAL_MS=300000
# Base delay in milliseconds for sync retry exponential backoff
USERNAME_INDEXER_SYNC_RETRY_BASE_DELAY_MS=1000
# Maximum retry attempts for failed sync operations
USERNAME_INDEXER_SYNC_RETRY_MAX_ATTEMPTS=3
# Base delay in milliseconds for lock acquisition exponential backoff
USERNAME_INDEXER_LOCK_RETRY_BASE_DELAY_MS=50
# Maximum retry attempts for distributed lock acquisition
USERNAME_INDEXER_LOCK_RETRY_MAX_ATTEMPTS=5

# ===============================================
# Admin Route Configuration
# ===============================================

# Enable/disable the admin endpoint (/admin) for management operations
ADMIN_ROUTE_ENABLED=false
# Enable the /admin/device-check/reset endpoint that clears a device's Apple
# DeviceCheck two-bit state. Requires both ADMIN_ROUTE_ENABLED=true AND
# DEVICE_CHECK_IOS_ENABLED=true to actually mount.
DEVICE_CHECK_RESET_ENABLED=false

# ===============================================
# Debug Routes (DO NOT enable in production)
# ===============================================

# Enable /debug/heapdump (V8 heap snapshot, basic-auth gated) and /debug/memory (process.memoryUsage)
DEBUG_HEAPDUMP_ENABLED=false

# Enable /debug/query (read-only SQL proxy for diagnostics, basic-auth gated)
DEBUG_SQL_ENABLED=false

# Minimum seconds between successful /debug/heapdump invocations (anti-abuse; one hour by default)
DEBUG_HEAPDUMP_COOLDOWN_SECONDS=3600

# ===============================================
# Statement Store Configuration
# ===============================================

# Enable/disable the statement store subscription daemon
PUSH_SUBSCRIPTIONS_INDEXER_ENABLED=false

# Enable browser Web Push subscriptions and host-triggered broadcasts
WEB_PUSH_ENABLED=false
# VAPID keys for browser Web Push. Generate a key pair with the web-push CLI or equivalent.
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com

# Enable/disable the invitation ticket daemon (fills invite ticket pool on-chain)
INVITATION_TICKET_DAEMON_ENABLED=false

# Free username registration queue
REGISTRATION_QUEUE_ENABLED=false
REGISTRATION_QUEUE_MAX_CAPACITY=100000

# ===============================================
# Authentication Configuration
# ===============================================

# Global flag to enable/disable authentication requirements (disabled by default for local development)
AUTH_ENABLED=false
# When false, requests without auth headers will be allowed through. When true, auth headers are required.
ENFORCE_AUTH=false
# Secret key for JWT token
JWT_AUTH_SECRET="a-very-strong-jwt-secret-key-that-you-need-to-change"
# When true, dim-ticket, invitation-ticket, notify, turn, and usernames routes require JWT
JWT_AUTH_ENFORCED=false
REFRESH_TOKEN_DURATION_DAYS=30
# Lifetime in seconds for challenges issued by POST /api/v1/auth/challenges.
# A challenge older than this when consumed is treated as not found.
# Default 5 minutes — long enough for slow networks, short enough to limit
# the replay window.
CHALLENGE_TTL_SECONDS=300

# Comma-separated list of authorized Android package names
ANDROID_PACKAGE_NAMES=
# SHA-256 hex digest (64 lowercase hex chars) of the Google Play Store app
# signing certificate. Attestations whose signingDigest matches this value
# are classified as appFromOfficialStore=true.
ANDROID_SIGNING_DIGEST_PLAYSTORE=
# SHA-256 hex digest (64 lowercase hex chars) of the Nova website (Vanilla
# APK) signing certificate. Attestations whose signingDigest matches this
# value are accepted with appFromOfficialStore=false.
ANDROID_SIGNING_DIGEST_WEBSITE=
# Lifetime in seconds for the short-lived attestation token issued by
# POST /api/v1/auth/android/attestation. The token must be presented to
# POST /api/v1/auth/token within this window.
ANDROID_ATTESTATION_TOKEN_TTL_SECONDS=60
# URL for Google's Android Keystore attestation revocation list. Override only
# for testing or proxying; defaults to the public Google endpoint.
ANDROID_ATTESTATION_CRL_URL=https://android.googleapis.com/attestation/status
# Cache TTL for the revocation list. Default 1 hour per spec. A failed refresh
# leaves the previous snapshot in place.
ANDROID_ATTESTATION_CRL_CACHE_TTL=1 hour
# Comma-separated list of authorized iOS package names
IOS_PACKAGE_NAMES=
# Comma-separated list of authorized Apple App IDs
APPLE_APP_ATTEST_APP_IDS=
# Apple Developer Team ID for DeviceCheck and App Attest services
APPLE_TEAM_ID=
# Key ID for the Apple DeviceCheck private key
DEVICE_CHECK_KEY_ID=
# Apple DeviceCheck private key (base64-encoded .p8 content)
DEVICE_CHECK_PRIVATE_KEY=
# Apple DeviceCheck API URL
DEVICE_CHECK_URL=https://api.devicecheck.apple.com/v1
# Enable Apple DeviceCheck for iOS username registration. When false, the DC
# middleware and route-side register call are no-ops and the DEVICE_CHECK_*
# env vars above are not required at startup.
DEVICE_CHECK_IOS_ENABLED=false

# Google Play Integrity verification mode: strict | relaxed_device | relaxed_all.
#   strict         — production (polkadot/westend2): require a Play Store
#                    build on a hardware-backed, non-rooted device.
#   relaxed_device — nightly/paseo: relax device integrity verdicts while
#                    keeping app recognition and licensing strict.
#   relaxed_all    — preview/debug: also accept UNRECOGNIZED_VERSION and
#                    UNLICENSED app licensing for sideloaded builds.
PLAY_INTEGRITY_MODE=strict
# Base64 encoded JSON string containing Google service account credentials for Play Integrity API
GOOGLE_CREDENTIALS=

# Configuration for Apple APN
APN_PRIVATE_KEY=
APN_PRIVATE_KEY_DEV=
APN_KEY_ID=
APN_KEY_ID_DEV=
APN_TEAM_ID=
# Comma-separated list of bundle identifiers for APN notifications (e.g., com.example.app)
APN_TOPICS=
# Default APN environment for non-development bundle IDs (true=production, false=sandbox)
APN_PRODUCTION=false
# Bundle ID suffixes that route to both APN development and production environments (default: .develop)
APN_DEVELOPMENT_SUFFIXES=
# Whether to route APN notifications to both development and production environments (default: false)
DUAL_FLOW_NOTIFICATIONS_ENABLED=false

# ===============================================
# System Configuration
# ===============================================

# Port number for the HTTP server
PORT=8080
# PostgreSQL connection string for the application database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity
# Maximum number of connections in the web database pool
DB_POOL_MAX=25
# Idle timeout for web database pool connections
DB_POOL_IDLE_TIMEOUT="45 seconds"
# Maximum lifetime for web database pool connections
DB_POOL_MAX_LIFETIME="12 minutes"
# Connection timeout for the web database pool
DB_POOL_CONNECT_TIMEOUT="12 seconds"
# Keep-alive interval for web database pool connections
DB_POOL_KEEP_ALIVE="30 seconds"
# Socket inactivity timeout for web database pool connections (TCP keepalive does not reset it)
DB_POOL_SOCKET_TIMEOUT="30 seconds"
# Postgres statement_timeout for web pool connections
DB_STATEMENT_TIMEOUT="30 seconds"
# Postgres lock_timeout for web pool connections
DB_LOCK_TIMEOUT="5 seconds"
# Postgres idle_in_transaction_session_timeout for web pool connections
DB_IDLE_IN_TRANSACTION_TIMEOUT="60 seconds"
# Maximum number of connections in the leader election database pool
# TODO: drop to 2 once all daemons are migrated to the leader-election pool
LEADER_DB_POOL_MAX=50
# Idle timeout for leader election database pool connections
LEADER_DB_POOL_IDLE_TIMEOUT="30 seconds"
# Connection timeout for the leader election database pool
LEADER_DB_POOL_CONNECT_TIMEOUT="12 seconds"
# TCP keepalive idle time before sending probes on leader election connections
LEADER_DB_KEEPALIVES_IDLE="10 seconds"
# How often the leader election reaper checks for stale entries
LEADER_DB_REAPER_INTERVAL="60 seconds"
# Sampling rate for request metrics (between 0 and 1)
REQUEST_SAMPLE_RATE=0.1
# Maximum time in milliseconds to wait for a route handler to complete
ROUTE_TIMEOUT=32000
# Enable/disable the block finalization monitoring daemon
FINALIZED_BLOCK_DAEMON_ENABLED=true
# Maximum time in milliseconds to wait for a block to be finalized
FINALIZED_BLOCK_TIMEOUT=90000

# ===============================================
# Swagger Authentication
# ===============================================

# Username for accessing Swagger documentation
SWAGGER_USERNAME=swagger
# Password for accessing Swagger documentation
SWAGGER_PASSWORD=swagger

# ===============================================
# Explorer Configuration
# ===============================================

# Options: Subscan, PolkadotJS
EXPLORER=PolkadotJS
# URL for the explorer
EXPLORER_URL=ws://localhost:9944

# ===============================================
# Batch Processing Configuration
# ===============================================

REGISTER_USERNAME_BATCH_SIZE=100

# ===============================================
# dotNS Gateway (Asset Hub) Configuration
# ===============================================

# Master feature flag for the dotNS gateway subsystem (route validation, AH client,
# DotnsChainBounds, DotnsGatewayAPI, reservations daemon). When false, the register
# route rejects any request that includes a `dotns` block with 400 and the daemon
# stays offline. Required to be true in environments where dotNS dual-write is wanted.
DOTNS_GATEWAY_ENABLED=false
# Comma-separated WSS endpoints for the Asset Hub chain hosting pallet_dotns_gateway.
# Required only when DOTNS_GATEWAY_ENABLED=true; otherwise unused.
# Set to a chopsticks endpoint locally (e.g. ws://chopsticks_ah_next:8000) and to the
# production AH RPC in prod. The attester key MUST hold AttestationAllowance on AH —
# without it, every submission terminal-fails with NoAttestationAllowance.
ASSET_HUB_RPC_ENDPOINTS=
# Maximum number of reservations submitted in a single batched dotNS gateway extrinsic.
DOTNS_RESERVE_BATCH_SIZE=50
# Maximum time to wait for the first transaction event when submitting a dotNS reservation.
DOTNS_RESERVE_SUBMIT_TIMEOUT="12 seconds"
# Daemon-side submit margin: seconds shaved off MaxValiditySeconds when the daemon
# decides whether a reserved row is still fresh enough to submit. Prevents in-flight
# expiry between pickup and inclusion.
DOTNS_SIGNED_AT_SAFETY_MARGIN_SECONDS=60
# Intake-side strict bound: maximum candidate-signature age (seconds) accepted at the
# register route. MUST be small enough that, after pickup latency + chain inclusion +
# DOTNS_SIGNED_AT_SAFETY_MARGIN_SECONDS, the signature is still inside MaxValiditySeconds.
# The DotnsGatewayAPI layer enforces this invariant at startup and refuses to come up
# if violated. With MaxValiditySeconds=300 and the defaults below, daemon budget is
# 300 - 60 - 120 = 120s, comfortable for AH inclusion.
DOTNS_INTAKE_FRESHNESS_MAX_AGE_SECONDS=120

# ===============================================
# WebRTC / TURN Configuration
# ===============================================

# Base64-encoded shared secret for HMAC-based TURN credential generation
TURN_SECRET=Y2hhbmdlLW1lLXRvLWEtcmVhbC1zZWNyZXQ=
# HMAC algorithm for TURN credential generation (Options: SHA1, SHA256, SHA384, SHA512)
TURN_AUTH_ALGORITHM=SHA1
# Time-to-live in seconds for generated TURN credentials (default: 1800)
TURN_TTL="30 minutes"
# TURN server realm for credential generation
TURN_REALM=placeholder
# Comma-separated ICE server URLs (stun:host:port, turn:host:port?transport=udp)
ICE_SERVERS=

# ===============================================
# Observability Configuration
# ===============================================

# Sentry DSN for error tracking
SENTRY_DSN=
# Deployment environment name for Sentry (e.g., production, staging, development)
DEPLOYMENT_ENVIRONMENT=
# Sampling rate for trace export (0.0 to 1.0, default: 0.1)
SENTRY_TRACE_SAMPLE_RATE=0.1
# Service name identifier for OpenTelemetry tracing and metrics
OTEL_SERVICE_NAME="Identity Backend API"
# OTel span processor: batch for production, simple for tests that must flush before teardown
OTEL_SPAN_PROCESSOR=batch
