{
  "name": "identity-backend-container",
  "private": true,
  "version": "1.9.0",
  "description": "",
  "type": "module",
  "exports": {
    "./v1": {
      "import": {
        "default": "./src/routes/v1/mod.ts"
      }
    },
    "./paths": {
      "import": {
        "default": "./lib/paths.js"
      }
    }
  },
  "scripts": {
    "dev": "bun --watch ./src/main.ts",
    "start": "bun run src/main.ts",
    "typecheck": "tsgo --noEmit --incremental",
    "db:generate": "pnpm turbo build && bun drizzle-kit -- generate",
    "db:migrate": "bun drizzle-kit -- migrate",
    "db:studio": "bun drizzle-kit -- studio",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "COVERAGE=true vitest run --project unit --project integration",
    "test:ui": "vitest --ui",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'",
    "check:env-sync": "bun run ./scripts/check-env-config-sync.ts && bun run ./scripts/check-compose-env-sync.ts",
    "provision:vouchers": "tsx scripts/provision-voucher-secrets.ts"
  },
  "lint-staged": {
    ".env.example": [
      "bun run ./scripts/check-env-config-sync.ts"
    ],
    "src/config.ts": [
      "bun run ./scripts/check-env-config-sync.ts"
    ]
  },
  "keywords": [],
