{
  "name": "@identity-backend/effect-vitest-gherkin",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --incremental",
    "test": "vitest run",
    "test:types": "tstyche",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {},
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "tsdown": "catalog:",
    "tstyche": "^7.1.0",
    "effect": "catalog:",
    "fast-check": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/vitest": "*",
    "vitest": "*",
    "effect": "*"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
