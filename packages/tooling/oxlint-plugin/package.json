{
  "name": "@identity-backend/oxlint-plugin",
  "private": true,
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "description": "Oxlint plugin for Identity Backend project",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "typecheck": "tsgo --noEmit --incremental",
    "format": "dprint fmt",
    "test": "backend run --cmd 'vitest run'",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'",
    "test:run": "vitest run --coverage",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {
    "@oxc-project/types": "^0.126.0",
    "@oxlint/plugins": "^1.60.0",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@identity-backend/vitest-config": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxlint": "^1.60.0",
    "tsdown": "catalog:",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
