{
  "name": "@identity-backend/observability",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --incremental",
    "test": "vitest run",
    "test:run": "vitest run",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {
    "@identity-backend/schema-extensions": "workspace:^",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/opentelemetry": "catalog:",
    "@effect/vitest": "catalog:",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@opentelemetry/api": "^1.9",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/opentelemetry": "catalog:",
    "@opentelemetry/api": "^1.9",
    "effect": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
