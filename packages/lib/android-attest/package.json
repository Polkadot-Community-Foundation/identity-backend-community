{
  "name": "@identity-backend/android-attest",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.0.1",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./testing": {
      "@identity-backend/source": "./src/testing/mod.ts",
      "default": "./dist/testing.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "test": "vitest run",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'",
    "typecheck": "tsgo --noEmit --incremental",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {
    "@identity-backend/schema-extensions": "workspace:^",
    "@peculiar/asn1-android": "^2.7.0",
    "@peculiar/asn1-schema": "^2.7.0",
    "@peculiar/x509": "^1.14.3",
    "@std/crypto": "npm:@jsr/std__crypto@^1.1.0",
    "@std/encoding": "npm:@jsr/std__encoding@^1.0.5",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/testing": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "catalog:",
    "tsdown": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./testing": "./dist/testing.mjs",
      "./package.json": "./package.json"
    }
  }
}
