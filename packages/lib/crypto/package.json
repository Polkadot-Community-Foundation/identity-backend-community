{
  "name": "@identity-backend/crypto",
  "private": true,
  "license": "MIT",
  "version": "0.0.1",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./sr25519": {
      "@identity-backend/source": "./src/sr25519.ts",
      "default": "./dist/sr25519.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --incremental",
    "test": "vitest run",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {
    "@identity-backend/substrate-schema": "workspace:^",
    "@polkadot-labs/schnorrkel-wasm": "^0.0.7"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/testing": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@noble/hashes": "catalog:",
    "@std/bytes": "npm:@jsr/std__bytes@^1.0.2",
    "@vitest/coverage-v8": "catalog:",
    "effect": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./sr25519": "./dist/sr25519.mjs",
      "./package.json": "./package.json"
    }
  }
}
