{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@total-typescript/tsconfig/tsc/dom/library-monorepo",
  "compilerOptions": {
    "customConditions": ["@identity-backend/source"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": ["src", "tests"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
