{
  "name": "@identity-backend/auth",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.3.0",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./device-check/ios": {
      "@identity-backend/source": "./src/services/device-check/ios/mod.ts",
      "default": "./dist/device-check/ios.mjs"
    },
    "./services": {
      "@identity-backend/source": "./src/services/mod.ts",
      "default": "./dist/services.mjs"
    },
    "./types": {
      "@identity-backend/source": "./src/types.ts",
      "default": "./dist/types.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --incremental",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}",
    "test": "vitest run",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'"
  },
  "dependencies": {
    "@identity-backend/app-attest": "workspace:^",
    "@noble/hashes": "catalog:",
    "@std/bytes": "npm:@jsr/std__bytes@^1.0.2",
    "@std/crypto": "npm:@jsr/std__crypto@^1.1.0",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@effect/platform": "catalog:",
    "@effect/vitest": "catalog:",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/stryker-plugins": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "fast-check": "catalog:",
    "tsdown": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "effect": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform": "catalog:",
    "effect": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./device-check/ios": "./dist/device-check/ios.mjs",
      "./services": "./dist/services.mjs",
      "./types": "./dist/types.mjs",
      "./package.json": "./package.json"
    }
  }
}
