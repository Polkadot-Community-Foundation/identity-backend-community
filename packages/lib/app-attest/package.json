{
  "name": "@identity-backend/app-attest",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.0.3",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./Assertion": {
      "@identity-backend/source": "./src/assertion.ts",
      "default": "./dist/Assertion.mjs"
    },
    "./Attestation": {
      "@identity-backend/source": "./src/attestation.ts",
      "default": "./dist/Attestation.mjs"
    },
    "./Certificates": {
      "@identity-backend/source": "./src/certificates.ts",
      "default": "./dist/Certificates.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "test": "vitest run",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'",
    "typecheck": "tsgo --noEmit --incremental",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "catalog:",
    "@peculiar/x509": "^1.14.3",
    "@std/bytes": "npm:@jsr/std__bytes@^1.0.2",
    "@std/cbor": "npm:@jsr/std__cbor@^0.1.9",
    "@std/encoding": "npm:@jsr/std__encoding@^1.0.5",
    "asn1js": "^3.0.7"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@identity-backend/crypto": "workspace:^",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "catalog:",
    "effect": "catalog:",
    "tsdown": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./Assertion": "./dist/Assertion.mjs",
      "./Attestation": "./dist/Attestation.mjs",
      "./Certificates": "./dist/Certificates.mjs",
      "./package.json": "./package.json"
    }
  }
}
