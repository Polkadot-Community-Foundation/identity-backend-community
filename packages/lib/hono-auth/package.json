{
  "name": "@identity-backend/hono-auth",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.3.0",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./app-attest": {
      "@identity-backend/source": "./src/app-attest/mod.ts",
      "default": "./dist/app-attest.mjs"
    },
    "./auth": {
      "@identity-backend/source": "./src/auth/mod.ts",
      "default": "./dist/auth.mjs"
    },
    "./device-check": {
      "@identity-backend/source": "./src/device-check/mod.ts",
      "default": "./dist/device-check.mjs"
    },
    "./play-integrity": {
      "@identity-backend/source": "./src/play-integrity/mod.ts",
      "default": "./dist/play-integrity.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --incremental",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}",
    "test": "vitest run",
    "mutation": "backend run --cmd 'stryker run --incremental' --stryker",
    "mutation:full": "backend run --guard --cmd 'stryker run'"
  },
  "dependencies": {
    "@identity-backend/app-attest": "workspace:^",
    "@std/bytes": "npm:@jsr/std__bytes@^1.0.2",
    "@std/streams": "npm:@jsr/std__streams@^1.0.7"
  },
  "devDependencies": {
    "@effect/platform": "catalog:",
    "@effect/vitest": "catalog:",
    "@identity-backend/android-attest": "workspace:^",
    "@identity-backend/auth": "workspace:^",
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/stryker-plugins": "workspace:^",
    "@identity-backend/testing": "workspace:^",
    "@identity-backend/play-integrity": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "catalog:",
    "effect": "catalog:",
    "hono": "^4.12.22",
    "tsdown": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@effect/platform": "catalog:",
    "@identity-backend/android-attest": "workspace:^",
    "@identity-backend/auth": "workspace:^",
    "@identity-backend/play-integrity": "workspace:^",
    "effect": "catalog:",
    "hono": "^4.12.22"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./app-attest": "./dist/app-attest.mjs",
      "./auth": "./dist/auth.mjs",
      "./device-check": "./dist/device-check.mjs",
      "./play-integrity": "./dist/play-integrity.mjs",
      "./package.json": "./package.json"
    }
  }
}
