{
  "name": "@identity-backend/people-lite-fixtures",
  "private": true,
  "license": "GPL-3.0-or-later",
  "version": "0.0.1",
  "author": "Ryan Lee <ryan@parity.io>",
  "type": "module",
  "exports": {
    ".": {
      "@identity-backend/source": "./src/mod.ts",
      "default": "./dist/index.mjs"
    },
    "./proof-of-compute": {
      "@identity-backend/source": "./src/proof-of-compute.ts",
      "default": "./dist/proof-of-compute.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --incremental",
    "test": "vitest run",
    "test:run": "vitest run",
    "lint": "oxlint . ${AGENT:+--format=unix --quiet}"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "catalog:",
    "@polkadot-labs/hdkd": "0.0.19",
    "@polkadot-labs/hdkd-helpers": "0.0.19",
    "@polkadot-labs/schnorrkel-wasm": "^0.0.7",
    "scale-ts": "1.6.1",
    "verifiablejs": "^1.3.0"
  },
  "devDependencies": {
    "@identity-backend/oxlint-config": "workspace:^",
    "@identity-backend/vitest-config": "workspace:^",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "effect": "catalog:",
    "rimraf": "^6.0.1",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./proof-of-compute": "./dist/proof-of-compute.mjs",
      "./package.json": "./package.json"
    }
  },
  "inlinedDependencies": {
    "effect": "3.21.2"
  }
}
