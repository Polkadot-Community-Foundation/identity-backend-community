#!/bin/sh
# Husky v9 prepare-commit-msg hook — AI co-author trailer stripping
#
# Strips AI agent co-authorship trailers while preserving human pair attribution.
# Uses grep/mv pattern (POSIX-safe) instead of sed -i (BSD/GNU incompatible).
#
# Target AI tools (email fingerprints):
# - Claude Code: noreply@anthropic.com
# - Cursor: cursoragent@cursor.com
# - Aider: noreply@aider.dev
# - Windsurf: cascade@windsurf.com
# - OpenCode/Sisyphus: clio-agent@sisyphuslabs.ai

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only process standard commits and message-based commits
# NEVER modify merge, squash, or amend messages
case "$COMMIT_SOURCE" in
  merge|squash)
    exit 0
    ;;
esac

if [ -f "$COMMIT_MSG_FILE" ]; then
  temp_file=$(mktemp)

  # Strip AI co-author trailers (preserve human co-authors)
  # Anchors patterns to '>' to prevent substring false positives
  grep -v -E -i "^Co-?-?[Aa]uthored-by:.*<.*(noreply@anthropic\.com|cursoragent@cursor\.com|noreply@aider\.dev|cascade@windsurf\.com|clio-agent@sisyphuslabs\.ai)>" "$COMMIT_MSG_FILE" > "$temp_file"

  # Only replace if filtered result is non-empty
  if [ -s "$temp_file" ]; then
    mv "$temp_file" "$COMMIT_MSG_FILE"
  else
    rm "$temp_file"
    echo "Error: Commit message cannot consist solely of AI co-author trailers" >&2
    exit 1
  fi
fi
